{
  "name": "batteryincluded",
  "type": "module",
  "version": "1.0.3",
  "description": "A TypeScript client for the BatteryIncluded API",
  "author": "Frederik Bußmann <frederik@bussmann.io>",
  "license": "MIT",
  "repository": "bussmann-io/batteryincluded-ts",
  "keywords": ["batteryincluded", "api", "sdk", "typescript", "e-commerce", "ai", "search"],
  "exports": {
    ".": "./dist/index.mjs"
  },
  "types": "./dist/index.d.mts",
  "bin": {
    "batteryincluded": "dist/cli/index.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "obuild",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepack": "bun run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "autodisco": "^2.0.5",
    "c12": "^3.3.4",
    "citty": "^0.2.2",
    "defu": "^6.1.7",
    "dotenv": "^17.4.2",
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@types/node": "^24.12.4",
    "eslint": "^10.6.0",
    "msw": "^2.14.6",
    "obuild": "^0.4.37",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
